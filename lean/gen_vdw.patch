@@ -61,6 +67,22 @@ def main (args : List String) : IO UInt32 := do
     | _, _, _ =>
       IO.eprintln "lratcatch-gen: n, s, t must be numbers"
       return 1
+  | ["vdw", lenStr, nStr, outFile] =>
+    match lenStr.toNat?, nStr.toNat? with
+    | some len, some n =>
+      if len == 0 then
+        IO.eprintln "lratcatch-gen: len must be positive"
+        return 1
+      let cnf := LRATCatcher.VdW.encode2 len n
+      unless LRATCatcher.dimacsRoundTrip cnf do
+        IO.eprintln "lratcatch-gen: round-trip self-check failed"
+        return 1
+      writeOutput outFile cnf.dimacs
+      IO.println s!"lratcatch-gen: wrote encode2 {len} {n} to {outFile}"
+      return 0
+    | _, _ =>
+      IO.eprintln "lratcatch-gen: len and n must be numbers"
+      return 1
   | _ =>
     IO.eprintln usage
     return 1
